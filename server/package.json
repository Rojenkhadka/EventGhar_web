{
  "name": "eventghar-server",
  "version": "1.0.0",
  "description": "EventGhar Backend API Server",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "lsof -ti :4000 | xargs kill -9 2>/dev/null; node src/index.js",
    "dev": "lsof -ti :4000 | xargs kill -9 2>/dev/null; nodemon src/index.js",
    "test": "jest --verbose",
    "test:watch": "jest --watch --verbose"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/src/__tests__/**/*.test.js"],
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "transformIgnorePatterns": [],
    "silent": true
  },
  "keywords": [
    "eventghar",
    "events",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "babel-jest": "^30.2.0",
    "jest": "^30.2.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}
